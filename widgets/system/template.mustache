<div class="card">
  <div class="row">
    <div class="label-group">
      <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="4" y="4" width="16" height="16" rx="2"/>
        <rect x="9" y="9" width="6" height="6" rx="1"/>
        <line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/>
        <line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/>
        <line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="15" x2="23" y2="15"/>
        <line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="15" x2="4" y2="15"/>
      </svg>
      <span class="label">CPU</span>
    </div>
    <span class="value">{{cpu_usage}}%</span>
  </div>
  <div class="bar"><div class="fill {{cpu_color}}" style="width:{{cpu_percent}}%"></div></div>
</div>

<div class="card">
  <div class="row">
    <div class="label-group">
      <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="2" y="7" width="20" height="10" rx="2"/>
        <line x1="6" y1="11" x2="6" y2="13"/><line x1="9" y1="11" x2="9" y2="13"/>
        <line x1="12" y1="11" x2="12" y2="13"/><line x1="15" y1="11" x2="15" y2="13"/>
        <line x1="18" y1="11" x2="18" y2="13"/>
        <line x1="6" y1="7" x2="6" y2="5"/><line x1="18" y1="7" x2="18" y2="5"/>
      </svg>
      <span class="label">RAM</span>
    </div>
    <span class="value">{{used_memory_gb}} / {{total_memory_gb}} GB</span>
  </div>
  <div class="bar"><div class="fill {{ram_color}}" style="width:{{ram_percent}}%"></div></div>
</div>

{{#disks}}
<div class="card">
  <div class="row">
    <div class="label-group">
      <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <ellipse cx="12" cy="7" rx="9" ry="3"/>
        <path d="M3 7v10c0 1.66 4.03 3 9 3s9-1.34 9-3V7"/>
        <path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3"/>
      </svg>
      <span class="label">{{name}}</span>
    </div>
    <span class="value">{{used_gb}} / {{total_gb}} GB</span>
  </div>
  <div class="bar"><div class="fill {{color}}" style="width:{{percent}}%"></div></div>
</div>
{{/disks}}

{{#networks}}
<div class="card">
  <div class="row">
    <div class="label-group">
      <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="12" y1="2" x2="12" y2="22"/>
        <polyline points="17 7 12 2 7 7"/>
        <polyline points="17 17 12 22 7 17"/>
      </svg>
      <span class="label">{{name}}</span>
    </div>
    <div class="speeds">
      <span class="speed-down">↓ {{rx}}</span>
      <span class="speed-up">↑ {{tx}}</span>
    </div>
  </div>
</div>
{{/networks}}
