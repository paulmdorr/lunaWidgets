{
  "identifier": "template",
  "description": "Capabilities for widget windows",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:window:allow-set-always-on-bottom",
    "core:window:allow-start-dragging",
    "window-state:default",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [{ "url": "https://**" }]
    }
  ]
}
