{
  "identifier": "plugin-runner",
  "description": "Capabilities for plugin runner windows",
  "windows": ["plugin-runner"],
  "permissions": [
    "core:default",
    "core:window:allow-set-always-on-bottom",
    "core:window:allow-set-min-size",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [{ "url": "https://api.notion.com/**" }]
    }
  ]
}
