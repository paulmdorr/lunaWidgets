{
  "identifier": "default",
  "description": "Default capabilities for the widget",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-always-on-bottom",
    "core:window:allow-set-min-size",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        { "url": "https://api.notion.com/**" }
      ]
    }
  ]
}
