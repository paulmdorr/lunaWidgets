{
  "$schema": "https://raw.githubusercontent.com/nicecrab/schemastore/master/src/schemas/json/tauri-conf-v2.json",
  "productName": "luna-widgets",
  "version": "0.1.0",
  "identifier": "com.luna-widgets.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Luna Widgets",
        "width": 360,
        "height": 500,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "resizable": true,
        "minWidth": 280,
        "minHeight": 200,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
