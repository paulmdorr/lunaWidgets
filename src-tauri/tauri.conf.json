{
  "$schema": "https://raw.githubusercontent.com/nicecrab/schemastore/master/src/schemas/json/tauri-conf-v2.json",
  "productName": "Luna Widgets",
  "version": "0.1.0",
  "identifier": "com.luna-widgets.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "bundle": {
    "resources": {
      "../widgets": "widgets"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": null
    }
  }
}
